{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "开源阅读",
  "version": "0.8.0",
  "identifier": "com.legado-tauri",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "开源阅读",
        "width": 1000,
        "height": 800,
        "minWidth": 500,
        "minHeight": 600,
        "visible": true,
        "devtools": false,
        "resizable": true,
        "maximizable": true,
        "minimizable": true,
        "decorations": false,
        "transparent": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**"]
      }
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["legado", "yuedu"]
      },
      "mobile": [
        {
          "scheme": ["legado", "yuedu"],
          "appLink": false
        }
      ]
    }
  }
}
